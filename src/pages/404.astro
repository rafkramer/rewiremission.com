---
// Branded 404. GitHub Pages serves 404.html automatically.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Page not found - Rewire</title>
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#13223F" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%2313223F'/%3E%3Ccircle cx='32' cy='32' r='14' fill='%232A1E5C'/%3E%3Ccircle cx='32' cy='32' r='14' fill='none' stroke='%2386D8DF' stroke-opacity='0.6' stroke-width='1.5'/%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Hanken+Grotesk:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="drift" aria-hidden="true"><i class="a"></i><i class="b"></i></div>

    <main class="page">
      <p class="eyebrow">404</p>
      <h1>Lost in <em>thought.</em></h1>
      <p class="sub">This page does not exist. Your mind still does.</p>
      <a class="pill-btn" href="/">Back home</a>
    </main>

    <footer>
      <a href="/">Home</a><span class="sep">·</span><a href="/privacy">Privacy</a><span class="sep">·</span><a href="/terms">Terms</a><span class="sep">·</span><span>© 2026 Kramer Ventures GmbH</span>
    </footer>

    <style is:global>
      :root {
        --bg: #13223F;
        --ink-bright: #F2F1EF;
        --ink-muted: rgba(235, 235, 235, 0.60);
        --serif: 'Instrument Serif', Georgia, serif;
        --sans: 'Hanken Grotesk', -apple-system, sans-serif;
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        background: var(--bg);
        color: var(--ink-muted);
        font-family: var(--sans);
        font-weight: 300;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }

      ::selection { background: rgba(134, 216, 223, 0.20); color: #fff; }

      .drift { position: fixed; inset: 0; pointer-events: none; z-index: -1; }
      .drift i { position: absolute; display: block; border-radius: 50%; filter: blur(48px); }
      .drift .a {
        width: 72vmax; height: 56vmax; left: -20%; top: -24%;
        background: radial-gradient(50% 50% at 50% 50%, rgba(70, 90, 135, 0.45), transparent 70%);
        animation: driftA 55s ease-in-out infinite alternate;
      }
      .drift .b {
        width: 62vmax; height: 50vmax; right: -20%; bottom: -22%;
        background: radial-gradient(50% 50% at 50% 50%, rgba(48, 116, 128, 0.28), transparent 70%);
        animation: driftB 70s ease-in-out infinite alternate;
      }
      @keyframes driftA { to { transform: translate(9%, 12%) scale(1.18); } }
      @keyframes driftB { to { transform: translate(-10%, -10%) scale(1.12); } }

      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.028'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 9999;
      }

      .page {
        min-height: 100vh;
        min-height: 100svh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 6rem clamp(1.5rem, 7vw, 5rem) 4rem;
      }

      .eyebrow {
        font-size: 0.72rem;
        font-weight: 500;
        letter-spacing: 0.44em;
        text-indent: 0.44em;
        text-transform: uppercase;
        color: rgba(134, 216, 223, 0.6);
        margin-bottom: 2.2rem;
      }

      h1 {
        font-family: var(--serif);
        font-weight: 400;
        font-size: clamp(2.6rem, 7vw, 5rem);
        line-height: 1.1;
        letter-spacing: -0.012em;
        color: var(--ink-bright);
      }

      h1 em {
        font-style: italic;
        background: linear-gradient(105deg, #EDEBF7 10%, #C7D0F4 50%, #9FB3ED 90%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }

      .sub { margin-top: 1.5rem; font-size: 1.05rem; line-height: 1.75; }

      .pill-btn {
        display: inline-flex;
        align-items: center;
        margin-top: 3rem;
        background: #ECEBE9;
        color: #0D0D0D;
        text-decoration: none;
        font-size: 1rem;
        font-weight: 500;
        padding: 1.05rem 2.6rem;
        border-radius: 999px;
        box-shadow: 0 12px 32px rgba(0, 0, 0, 0.5), 0 0 60px rgba(150, 170, 240, 0.12);
        transition: background 0.3s ease, transform 0.2s ease;
      }
      .pill-btn:hover { background: #fff; transform: translateY(-1px); }

      footer {
        position: fixed;
        left: 0;
        right: 0;
        bottom: max(1.1rem, env(safe-area-inset-bottom));
        text-align: center;
        font-size: 0.62rem;
        letter-spacing: 0.06em;
        color: rgba(235, 235, 235, 0.28);
      }
      footer a { color: inherit; text-decoration: none; }
      footer a:hover { color: rgba(235, 235, 235, 0.6); }
      footer .sep { margin: 0 0.55em; }

      @media (prefers-reduced-motion: reduce) {
        .drift i { animation: none; }
      }
    </style>
  </body>
</html>
