---
// Affiliate dashboard - sample data engine in src/scripts/affiliates.js,
// labelled "Verified by AppStack" until the real API sync lands.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <title>Rewire Affiliates - Dashboard</title>
    <meta name="description" content="Your Rewire affiliate dashboard. Traffic, installs, trials, and earnings - verified by AppStack." />
    <meta name="robots" content="noindex" />
    <meta name="theme-color" content="#13223F" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='14' fill='%2313223F'/%3E%3Ccircle cx='32' cy='32' r='14' fill='%232A1E5C'/%3E%3Ccircle cx='32' cy='32' r='14' fill='none' stroke='%2386D8DF' stroke-opacity='0.6' stroke-width='1.5'/%3E%3C/svg%3E" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Hanken+Grotesk:wght@300;400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="drift" aria-hidden="true"><i class="a"></i><i class="b"></i></div>

    <!-- login gate -->
    <div class="gate" id="gate" hidden>
      <form class="gate-card" id="gate-form">
        <span class="tag">Rewire · Affiliates</span>
        <h1>Welcome back.</h1>
        <p>Enter your affiliate code to open your dashboard.</p>
        <input id="gate-code" type="text" placeholder="Your affiliate code" autocomplete="off" spellcheck="false" />
        <button type="submit">Open dashboard</button>
        <p class="err" id="gate-err"></p>
        <p class="hint">Preview build with sample data - try <b>NEURO7</b>, <b>MIA</b> or <b>CALM</b></p>
      </form>
    </div>

    <header class="topbar">
      <a class="brand" href="/">
        <span class="word">Rewire</span>
        <span class="tag">Affiliates</span>
      </a>
      <div class="who" id="who"></div>
    </header>

    <main id="main" hidden>
      <div class="greet-row">
        <div class="greet rise">
          <h1 id="greet-h"></h1>
          <p id="greet-p"></p>
        </div>
        <div class="range rise d1" id="range" role="tablist" aria-label="Date range">
          <button data-days="7">7D</button>
          <button data-days="30" class="on">30D</button>
          <button data-days="90">90D</button>
          <button data-days="0">All</button>
        </div>
      </div>

      <div class="tiles" id="tiles"></div>

      <div class="grid">
        <div class="card rise d1 chart-card">
          <div class="card-head">
            <h2>Trends</h2>
            <span class="label" id="chart-range-label"></span>
          </div>
          <div class="metric-tabs" id="metric-tabs" role="tablist" aria-label="Metric"></div>
          <div class="chart-wrap" id="chart-wrap">
            <svg id="chart" aria-label="Daily trend"></svg>
            <div class="chart-tip" id="chart-tip"></div>
          </div>
          <div class="chart-meta" id="chart-meta"></div>
        </div>

        <div class="card rise d2 page-card">
          <div class="card-head"><h2>Your page</h2><span class="handle-pill" id="page-handle"></span></div>
          <div class="url-row">
            <span class="url-box" id="page-url-text"></span>
            <button class="mini-btn" id="copy-btn" type="button">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy
            </button>
            <a class="mini-btn" id="open-btn" target="_blank" rel="noopener">Open</a>
          </div>
          <p class="page-note">This is your personal landing page. Every download and every dollar it drives is attributed to you through <a href="https://appstack.tech" target="_blank" rel="noopener">AppStack</a>.</p>
          <div class="preview-frame" aria-hidden="true">
            <div class="chrome"><span class="dot"></span><span class="dot"></span><span class="dot"></span><span class="addr" id="preview-addr"></span><span style="width:24px"></span></div>
            <div class="preview-viewport"><iframe id="preview-iframe" tabindex="-1" title="Landing page preview" loading="lazy"></iframe></div>
          </div>
        </div>
      </div>

      <div class="card rise d2" style="margin-bottom:1.1rem">
        <div class="card-head">
          <h2>Performance</h2>
          <a class="verified" href="https://appstack.tech" target="_blank" rel="noopener" title="Attribution and revenue data confirmed by AppStack">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
            Verified by AppStack
          </a>
        </div>
        <div class="appstack">
          <div class="funnel" id="funnel"></div>
          <div class="money" id="money"></div>
        </div>
      </div>

      <div class="card rise d3">
        <div class="card-head">
          <h2>Payouts</h2>
          <span class="label">Paid on the 1st, monthly</span>
        </div>
        <div class="payout-grid" id="payout-tiles"></div>
        <div style="overflow-x:auto">
          <table>
            <thead>
              <tr><th>Month</th><th class="num">Verified revenue</th><th class="num">Your share</th><th class="num">Your cut</th><th style="text-align:right">Status</th></tr>
            </thead>
            <tbody id="payout-rows"></tbody>
          </table>
        </div>
      </div>

      <div class="card refer rise d4" style="margin-top:1.1rem">
        <div class="refer-copy">
          <h2>Refer an affiliate, <em>earn $300.</em></h2>
          <p>Know a creator who fits Rewire? Send them your invite link. Once they join the program and their first payout clears, a $300 bonus lands in your next payout.</p>
        </div>
        <div class="refer-action">
          <div class="url-row">
            <span class="url-box" id="refer-url"></span>
            <button class="mini-btn" id="refer-copy-btn" type="button">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
              Copy
            </button>
          </div>
          <span class="refer-note">The link is tied to your account - we track the rest.</span>
        </div>
      </div>

      <p class="foot rise d4">Preview build with sample data - live tracking activates with your onboarding.<br />Questions? <a href="mailto:team@rewiremission.com">team@rewiremission.com</a></p>
    </main>

    <style is:global>
      :root {
        --bg: #13223F;
        --ink-bright: #F2F1EF;
        --ink: rgba(235, 235, 235, 0.86);
        --ink-muted: rgba(235, 235, 235, 0.60);
        --ink-faint: rgba(235, 235, 235, 0.42);
        --ink-ghost: rgba(235, 235, 235, 0.25);
        --serif: 'Instrument Serif', Georgia, serif;
        --sans: 'Hanken Grotesk', -apple-system, sans-serif;
        --accent: #86D8DF;
        --card-bg: rgba(255, 255, 255, 0.035);
        --card-line: rgba(255, 255, 255, 0.09);
      }

      * { margin: 0; padding: 0; box-sizing: border-box; }

      body {
        background: var(--bg);
        color: var(--ink-muted);
        font-family: var(--sans);
        font-weight: 300;
        -webkit-font-smoothing: antialiased;
        -webkit-tap-highlight-color: transparent;
        overflow-x: hidden;
        min-height: 100vh;
      }

      ::selection { background: rgba(134, 216, 223, 0.20); color: #fff; }

      .drift { position: fixed; inset: 0; pointer-events: none; z-index: -1; }
      .drift i { position: absolute; display: block; border-radius: 50%; filter: blur(52px); }
      .drift .a {
        width: 70vmax; height: 54vmax; left: -22%; top: -26%;
        background: radial-gradient(50% 50% at 50% 50%, rgba(70, 90, 135, 0.38), transparent 70%);
        animation: driftA 60s ease-in-out infinite alternate;
      }
      .drift .b {
        width: 60vmax; height: 48vmax; right: -22%; bottom: -24%;
        background: radial-gradient(50% 50% at 50% 50%, rgba(48, 116, 128, 0.22), transparent 70%);
        animation: driftB 75s ease-in-out infinite alternate;
      }
      @keyframes driftA { to { transform: translate(8%, 10%) scale(1.15); } }
      @keyframes driftB { to { transform: translate(-9%, -9%) scale(1.1); } }

      body::after {
        content: '';
        position: fixed;
        inset: 0;
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.028'/%3E%3C/svg%3E");
        pointer-events: none;
        z-index: 9999;
      }

      a { color: inherit; }
      a:focus-visible, button:focus-visible, input:focus-visible { outline: 1px solid var(--ink-faint); outline-offset: 4px; }

      .topbar {
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1.1rem clamp(1.2rem, 4vw, 2.6rem);
        background: rgba(19, 34, 63, 0.72);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.06);
      }

      .brand { display: flex; align-items: baseline; gap: 0.7rem; text-decoration: none; }
      .brand .word { font-family: var(--serif); font-size: 1.25rem; color: var(--ink-bright); letter-spacing: 0.01em; }
      .brand .tag {
        font-size: 0.6rem; font-weight: 500; letter-spacing: 0.3em; text-transform: uppercase;
        color: rgba(134, 216, 223, 0.75);
      }

      .who { display: flex; align-items: center; gap: 0.85rem; }
      .who .avatar {
        width: 34px; height: 34px; border-radius: 50%;
        overflow: hidden;
        display: grid; place-items: center;
        font-family: var(--serif); font-size: 1rem; color: #0f1c35;
        background: linear-gradient(135deg, #C7D0F4, #86D8DF);
      }
      .who .avatar img { width: 100%; height: 100%; object-fit: cover; display: block; }
      .who .meta { line-height: 1.25; text-align: right; }
      .who .name { font-size: 0.86rem; font-weight: 500; color: var(--ink); }
      .who .code { font-size: 0.72rem; letter-spacing: 0.03em; color: var(--ink-faint); }
      .who button {
        margin-left: 0.4rem;
        background: none;
        border: 1px solid rgba(255, 255, 255, 0.14);
        border-radius: 999px;
        color: var(--ink-faint);
        font-family: var(--sans);
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.12em;
        text-transform: uppercase;
        padding: 0.45rem 0.95rem;
        cursor: pointer;
        transition: color 0.3s ease, border-color 0.3s ease;
      }
      .who button:hover { color: var(--ink-bright); border-color: rgba(255, 255, 255, 0.32); }

      main {
        max-width: 72rem;
        margin: 0 auto;
        padding: 2.8rem clamp(1.2rem, 4vw, 2.6rem) 4rem;
      }

      .greet-row {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1.2rem;
        margin-bottom: 2rem;
      }
      .greet h1 {
        font-family: var(--serif);
        font-weight: 400;
        font-size: clamp(1.9rem, 4.5vw, 2.9rem);
        line-height: 1.12;
        color: var(--ink-bright);
      }
      .greet h1 em {
        font-style: italic;
        background: linear-gradient(105deg, #EDEBF7 10%, #C7D0F4 50%, #9FB3ED 90%);
        -webkit-background-clip: text;
        background-clip: text;
        color: transparent;
      }
      .greet p { margin-top: 0.5rem; font-size: 0.92rem; color: var(--ink-faint); }

      .range {
        display: inline-flex;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 999px;
        padding: 0.22rem;
        background: rgba(255, 255, 255, 0.03);
      }
      .range button {
        border: 0;
        background: none;
        color: var(--ink-faint);
        font-family: var(--sans);
        font-size: 0.74rem;
        font-weight: 500;
        letter-spacing: 0.1em;
        padding: 0.5rem 1.05rem;
        border-radius: 999px;
        cursor: pointer;
        transition: color 0.25s ease, background 0.25s ease;
      }
      .range button.on { background: rgba(134, 216, 223, 0.14); color: var(--ink-bright); }
      .range button:hover:not(.on) { color: var(--ink); }

      .card {
        border: 1px solid var(--card-line);
        border-radius: 22px;
        background: var(--card-bg);
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        padding: 1.6rem 1.7rem;
      }

      .card h2 {
        font-family: var(--serif);
        font-weight: 400;
        font-size: 1.35rem;
        color: var(--ink-bright);
        letter-spacing: 0.01em;
      }
      .card .card-head {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.8rem;
        margin-bottom: 1.4rem;
      }

      .label {
        font-size: 0.64rem;
        font-weight: 500;
        letter-spacing: 0.22em;
        text-transform: uppercase;
        color: var(--ink-faint);
      }

      .tiles {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1.1rem;
        margin-bottom: 1.1rem;
      }
      @media (max-width: 1200px) { .tiles { grid-template-columns: repeat(3, 1fr); } }
      .tile { padding: 1.35rem 1.5rem 1.3rem; }
      .tile[data-metric] { cursor: pointer; transition: border-color 0.3s ease, background 0.3s ease, transform 0.2s ease; }
      .tile[data-metric]:hover { border-color: rgba(255, 255, 255, 0.18); background: rgba(255, 255, 255, 0.055); transform: translateY(-1px); }
      .tile .label { display: block; margin-bottom: 0.65rem; }
      .tile .value {
        font-family: var(--serif);
        font-size: clamp(1.7rem, 3vw, 2.3rem);
        line-height: 1;
        color: var(--ink-bright);
      }
      .tile .delta { display: inline-block; margin-top: 0.6rem; font-size: 0.72rem; color: var(--ink-faint); }
      .tile .delta.up { color: rgba(134, 223, 177, 0.85); }
      .tile .delta.down { color: rgba(240, 160, 160, 0.85); }

      .grid {
        display: grid;
        grid-template-columns: 7fr 5fr;
        gap: 1.1rem;
        margin-bottom: 1.1rem;
      }
      .grid > *, .appstack > *, .tiles > * { min-width: 0; }

      .handle-pill {
        display: inline-flex;
        align-items: center;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 999px;
        padding: 0.32rem 0.75rem;
        background: rgba(255, 255, 255, 0.04);
        font-size: 0.72rem;
        letter-spacing: 0.03em;
        color: var(--ink-muted);
        white-space: nowrap;
      }

      .page-card .url-row { display: flex; gap: 0.6rem; margin-bottom: 1.1rem; }
      .url-box {
        flex: 1;
        display: flex;
        align-items: center;
        min-width: 0;
        border: 1px solid rgba(255, 255, 255, 0.12);
        border-radius: 12px;
        background: rgba(0, 0, 0, 0.18);
        padding: 0.8rem 1rem;
        font-size: 0.86rem;
        color: var(--ink);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        letter-spacing: 0.01em;
      }
      .mini-btn {
        border: 1px solid rgba(255, 255, 255, 0.14);
        background: rgba(255, 255, 255, 0.05);
        color: var(--ink);
        font-family: var(--sans);
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.06em;
        padding: 0 1.1rem;
        border-radius: 12px;
        cursor: pointer;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        transition: background 0.25s ease, color 0.25s ease, border-color 0.25s ease;
      }
      .mini-btn:hover { background: rgba(255, 255, 255, 0.1); color: var(--ink-bright); }
      .mini-btn.copied { border-color: rgba(134, 216, 223, 0.5); color: var(--accent); }
      .mini-btn svg { width: 0.95em; height: 0.95em; }

      .page-note { font-size: 0.78rem; line-height: 1.6; color: var(--ink-faint); }
      .page-note a {
        color: var(--ink-muted);
        text-decoration: underline;
        text-underline-offset: 3px;
        text-decoration-color: rgba(235, 235, 235, 0.35);
        transition: color 0.3s ease;
      }
      .page-note a:hover { color: var(--ink-bright); }

      .preview-frame {
        margin-top: 1.2rem;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 16px;
        overflow: hidden;
        background: #0e1a33;
      }
      .preview-frame .chrome {
        display: flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.55rem 0.9rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.07);
        background: rgba(255, 255, 255, 0.03);
      }
      .preview-frame .dot { width: 8px; height: 8px; border-radius: 50%; background: rgba(255, 255, 255, 0.14); }
      .preview-frame .addr {
        flex: 1;
        text-align: center;
        font-size: 0.66rem;
        letter-spacing: 0.04em;
        color: var(--ink-ghost);
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
      }
      .preview-viewport { position: relative; height: 300px; overflow: hidden; }
      .preview-viewport iframe {
        width: 200%;
        height: 600px;
        border: 0;
        transform: scale(0.5);
        transform-origin: 0 0;
        pointer-events: none;
      }

      .chart-card { display: flex; flex-direction: column; }
      .chart-card .card-head { margin-bottom: 1rem; }

      .metric-tabs {
        display: flex;
        gap: 0.45rem;
        overflow-x: auto;
        margin-bottom: 1.1rem;
        padding-bottom: 0.2rem;
        scrollbar-width: none;
      }
      .metric-tabs::-webkit-scrollbar { display: none; }
      .mtab {
        flex: none;
        border: 1px solid rgba(255, 255, 255, 0.12);
        background: transparent;
        color: var(--ink-faint);
        font-family: var(--sans);
        font-size: 0.68rem;
        font-weight: 500;
        letter-spacing: 0.09em;
        text-transform: uppercase;
        padding: 0.42rem 0.9rem;
        border-radius: 999px;
        cursor: pointer;
        transition: color 0.25s ease, background 0.25s ease, border-color 0.25s ease;
      }
      .mtab:hover { color: var(--ink); }

      .chart-wrap { position: relative; flex: 1; min-height: 250px; }
      .chart-wrap svg { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }
      .chart-tip {
        position: absolute;
        pointer-events: none;
        background: rgba(14, 26, 51, 0.94);
        border: 1px solid rgba(134, 216, 223, 0.25);
        border-radius: 10px;
        padding: 0.5rem 0.75rem;
        font-size: 0.72rem;
        color: var(--ink);
        white-space: nowrap;
        opacity: 0;
        transition: opacity 0.15s ease;
        transform: translate(-50%, -110%);
        z-index: 5;
      }
      .chart-tip .t-views { color: var(--accent); font-weight: 500; }
      .chart-meta {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1rem;
        margin-top: 1.15rem;
        padding-top: 1.05rem;
        border-top: 1px solid rgba(255, 255, 255, 0.06);
      }
      .chart-meta .m .label { display: block; margin-bottom: 0.35rem; }
      .chart-meta .m .v { font-family: var(--serif); font-size: 1.22rem; color: var(--ink-bright); }
      .chart-meta .m .v small { font-family: var(--sans); font-size: 0.68rem; color: var(--ink-faint); margin-left: 0.35em; }
      .chart-meta .m .v.up { color: #8CE0B7; }
      .chart-meta .m .v.down { color: #F0A9A9; }
      @media (max-width: 640px) { .chart-meta { grid-template-columns: repeat(2, 1fr); } }

      .verified {
        display: inline-flex;
        align-items: center;
        gap: 0.45rem;
        padding: 0.38rem 0.85rem;
        border: 1px solid rgba(134, 216, 223, 0.22);
        border-radius: 999px;
        background: rgba(134, 216, 223, 0.06);
        font-size: 0.64rem;
        font-weight: 500;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: rgba(134, 216, 223, 0.85);
        white-space: nowrap;
      }
      .verified svg { width: 1em; height: 1em; flex: none; }
      a.verified { text-decoration: none; transition: border-color 0.3s ease, background 0.3s ease, color 0.3s ease; }
      a.verified:hover { border-color: rgba(134, 216, 223, 0.5); background: rgba(134, 216, 223, 0.12); color: var(--accent); }

      .appstack {
        display: grid;
        grid-template-columns: 7fr 5fr;
        gap: 2.2rem;
        margin-bottom: 1.1rem;
      }
      @media (max-width: 860px) { .appstack { grid-template-columns: 1fr; } }

      .funnel .step { margin-bottom: 1.05rem; }
      .funnel .step:last-child { margin-bottom: 0; }
      .funnel .row1 { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 0.4rem; }
      .funnel .row1 .n { font-size: 0.82rem; color: var(--ink); }
      .funnel .row1 .v { font-family: var(--serif); font-size: 1.1rem; color: var(--ink-bright); }
      .funnel .bar { height: 10px; border-radius: 999px; background: rgba(255, 255, 255, 0.06); overflow: hidden; }
      .funnel .bar i {
        display: block;
        height: 100%;
        border-radius: 999px;
        background: linear-gradient(90deg, rgba(134, 216, 223, 0.85), rgba(159, 179, 237, 0.85));
