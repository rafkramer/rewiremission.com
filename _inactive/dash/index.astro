        transition: border-color 0.3s ease;
      }
      .gate-card input::placeholder { letter-spacing: 0.08em; text-transform: none; color: var(--ink-ghost); }
      .gate-card input:focus { outline: none; border-color: rgba(134, 216, 223, 0.5); }
      .gate-card button {
        width: 100%;
