      .refer p { font-size: 0.86rem; line-height: 1.65; color: var(--ink-muted); }
      .refer .url-row { display: flex; gap: 0.6rem; }
      .refer-note { display: block; margin-top: 0.6rem; font-size: 0.7rem; color: var(--ink-ghost); }
      @media (max-width: 980px) { .refer { grid-template-columns: 1fr; gap: 1.2rem; } }

