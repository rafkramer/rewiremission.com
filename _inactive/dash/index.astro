        padding: 0.95rem;
        cursor: pointer;
        transition: background 0.3s ease, transform 0.2s ease;
      }
      .gate-card button:hover { background: #fff; transform: translateY(-1px); }
      .gate-card .err { min-height: 1.2rem; margin: 0.8rem 0 0; font-size: 0.76rem; color: rgba(240, 160, 160, 0.9); }
      .gate-card .hint { margin-top: 1.3rem; font-size: 0.7rem; color: var(--ink-ghost); }
      .gate-card .hint b { font-weight: 500; color: var(--ink-faint); letter-spacing: 0.1em; }
      .gate-card.shake { animation: shake 0.4s ease; }
      @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-7px); }
        75% { transform: translateX(7px); }
      }

      .rise { opacity: 0; transform: translateY(16px); transition: opacity 0.9s ease, transform 0.9s cubic-bezier(0.2, 0.7, 0.2, 1); }
      body.in .rise { opacity: 1; transform: none; }
      .rise.d1 { transition-delay: 0.08s; }
      .rise.d2 { transition-delay: 0.16s; }
      .rise.d3 { transition-delay: 0.24s; }
      .rise.d4 { transition-delay: 0.32s; }

      @media (max-width: 980px) {
        .tiles { grid-template-columns: repeat(2, 1fr); }
        .grid { grid-template-columns: 1fr; }
      }
      @media (max-width: 640px) {
        .payout-grid { grid-template-columns: 1fr; }
        .who .meta { display: none; }
        .greet-row { align-items: flex-start; flex-direction: column; }
      }
      @media (prefers-reduced-motion: reduce) {
        .drift i { animation: none; }
        .rise { opacity: 1; transform: none; transition: none; }
      }
    </style>

    <script>
      import { RW } from '../../scripts/affiliates.js';

      const LS_KEY = 'rw_aff_code';
      const state = { aff: null, days: 30, metric: 'views' };
      const $ = (id) => document.getElementById(id);

      /* ---------- gate ---------- */
      function showGate() {
        $('main').hidden = true;
        $('who').innerHTML = '';
        $('gate').hidden = false;
        document.body.classList.remove('in');
        setTimeout(() => $('gate-code').focus(), 50);
      }
      $('gate-form').addEventListener('submit', (e) => {
        e.preventDefault();
        const a = RW.byCode($('gate-code').value);
        if (!a) {
          $('gate-err').textContent = 'Hmm, that code is not on the list. Try NEURO7.';
          const card = e.target;
          card.classList.remove('shake');
          void card.offsetWidth;
          card.classList.add('shake');
          return;
        }
        localStorage.setItem(LS_KEY, a.code);
        $('gate-err').textContent = '';
        enter(a);
      });

      function enter(a) {
        state.aff = a;
        $('gate').hidden = true;
        $('main').hidden = false;
        renderWho();
        renderTabs();
        renderAll();
        requestAnimationFrame(() => document.body.classList.add('in'));
      }

      /* ---------- topbar ---------- */
      function renderWho() {
        const a = state.aff;
        const person = a.person || a.name;
        const av = a.avatar || a.avatarUrl;
        $('who').innerHTML =
          '<div class="meta"><div class="name">' + person + '</div><div class="code">@' + a.handle + '</div></div>' +
          '<div class="avatar">' + (av ? '<img src="' + av + '" alt="" />' : person.charAt(0)) + '</div>' +
          '<button type="button" id="signout">Sign out</button>';
        $('signout').addEventListener('click', () => {
          localStorage.removeItem(LS_KEY);
          showGate();
        });
      }

      /* ---------- range ---------- */
      $('range').addEventListener('click', function (e) {
        const b = e.target.closest('button');
        if (!b) return;
        state.days = +b.dataset.days;
        this.querySelectorAll('button').forEach((x) => x.classList.remove('on'));
        b.classList.add('on');
        renderAll();
      });

      function rangeLabel() {
        return state.days === 0 ? 'Since you joined' : 'Last ' + state.days + ' days';
      }

      /* ---------- render ---------- */
      function renderAll() {
        const a = state.aff;
        const t = RW.totals(a.code, state.days);

        const h = new Date().getHours();
        const slot = h < 5 ? 'Up late' : h < 12 ? 'Good morning' : h < 18 ? 'Good afternoon' : 'Good evening';
        const first = a.person || a.name.split(' ')[0];
        $('greet-h').innerHTML = slot + ', <em>' + first + '.</em>';
        $('greet-p').textContent = 'Performance overview · ' + rangeLabel();

        renderTiles(a, t);
        renderChart(a);
        renderPage(a);
        renderFunnel(a, t);
        renderMoney(a, t);
        renderPayouts(a);
        renderRefer(a);
      }

      /* ---------- refer a creator ---------- */
      function renderRefer(a) {
        const display = 'rewiremission.com/affiliates?ref=' + a.handle;
        $('refer-url').textContent = display;
        $('refer-copy-btn').onclick = function () {
          const btn = this;
          navigator.clipboard.writeText('https://' + display).then(() => {
            btn.classList.add('copied');
            btn.lastChild.textContent = ' Copied';
            setTimeout(() => { btn.classList.remove('copied'); btn.lastChild.textContent = ' Copy'; }, 1600);
          });
        };
      }

      function renderTiles(a, t) {
        const prev = state.days ? RW.totals(a.code, state.days, state.days) : null;
        const defs = [
          ['Page views', t.views, prev && prev.views, false, 'views'],
          ['Link clicks', t.clicks, prev && prev.clicks, false, 'clicks'],
          ['Trial starts', t.trials, prev && prev.trials, false, 'trials'],
          ['Revenue', t.verifiedRevenue, prev && prev.verifiedRevenue, true, 'revenue'],
          ['Earnings', t.earnings, prev && prev.earnings, true, 'earnings']
        ];
        $('tiles').innerHTML = defs.map((d, i) => {
          const [label, val, prevVal, money, metric] = d;
          let deltaHtml;
          if (prevVal > 0) {
            const ch = (val - prevVal) / prevVal * 100;
            const cls = ch >= 0 ? 'up' : 'down';
            deltaHtml = '<span class="delta ' + cls + '">' + (ch >= 0 ? '▲ +' : '▼ ') + ch.toFixed(0) + '% vs previous</span>';
          } else {
            deltaHtml = '<span class="delta">' + rangeLabel() + '</span>';
          }
          return '<div class="card tile rise d' + Math.min(i, 4) + '" role="button" tabindex="0" data-metric="' + metric + '" title="Show ' + label.toLowerCase() + ' in Trends">' +
            '<span class="label">' + label + '</span><span class="value">' + (money ? RW.money(val) : RW.num(val)) + '</span>' + deltaHtml + '</div>';
        }).join('');
      }

      // tiles jump to their metric in the Trends chart
      $('tiles').addEventListener('click', (e) => {
        const tile = e.target.closest('[data-metric]');
        if (!tile) return;
        state.metric = tile.dataset.metric;
        renderChart(state.aff);
        document.querySelector('.chart-card').scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      });
      $('tiles').addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          const tile = e.target.closest('[data-metric]');
          if (!tile) return;
          e.preventDefault();
          tile.click();
        }
      });

      /* ---------- chart ---------- */
      const METRICS = [
        { key: 'views',    label: 'Views',    color: '#86D8DF', money: false, get: (r) => r.views },
        { key: 'clicks',   label: 'Clicks',   color: '#9FB3ED', money: false, get: (r) => r.clicks },
        { key: 'installs', label: 'Installs', color: '#B9A9F2', money: false, get: (r) => r.installs },
        { key: 'trials',   label: 'Trials',   color: '#EFB8C8', money: false, get: (r) => r.trials },
        { key: 'revenue',  label: 'Revenue',  color: '#F0CD8C', money: true,  get: (r) => r.revenue },
        { key: 'earnings', label: 'Earnings', color: '#8CE0B7', money: true,  get: (r) => r.revenue * state.aff.share }
      ];

      function currentMetric() { return METRICS.find((m) => m.key === state.metric); }
      function alphaColor(hex, a) {
        const v = parseInt(hex.slice(1), 16);
        return 'rgba(' + ((v >> 16) & 255) + ',' + ((v >> 8) & 255) + ',' + (v & 255) + ',' + a + ')';
      }
      function fmtVal(v, money) { return money ? RW.money(v) : RW.num(v); }
      function fmtTick(v, money) {
        const short = v >= 1000 ? (v / 1000).toFixed(v >= 10000 ? 0 : 1).replace(/\.0$/, '') + 'k' : String(Math.round(v));
        return money ? '$' + short : short;
      }
      function niceCeil(v) {
        const p = Math.pow(10, Math.floor(Math.log10(v || 1)));
        for (const mult of [1, 1.5, 2, 2.5, 3, 4, 5, 6, 8, 10]) if (mult * p >= v) return mult * p;
        return 10 * p;
      }

      function renderTabs() {
        const wrap = $('metric-tabs');
        wrap.innerHTML = METRICS.map((m) =>
          '<button class="mtab" type="button" role="tab" data-key="' + m.key + '">' + m.label + '</button>'
        ).join('');
        wrap.onclick = (e) => {
          const b = e.target.closest('.mtab');
          if (!b) return;
          state.metric = b.dataset.key;
          renderChart(state.aff);
        };
        styleTabs();
      }
      function styleTabs() {
        document.querySelectorAll('.mtab').forEach((b) => {
          const m = METRICS.find((x) => x.key === b.dataset.key);
          const on = m.key === state.metric;
          b.style.background = on ? alphaColor(m.color, 0.14) : '';
          b.style.borderColor = on ? alphaColor(m.color, 0.55) : '';
          b.style.color = on ? m.color : '';
          b.setAttribute('aria-selected', String(on));
        });
      }

      // Catmull-Rom smoothing, control points clamped to the plot area
      function smoothPath(pts, clampY) {
        if (pts.length < 3) return pts.map((p, i) => (i ? 'L' : 'M') + p.x.toFixed(1) + ' ' + p.y.toFixed(1)).join(' ');
        let d = 'M' + pts[0].x.toFixed(1) + ' ' + pts[0].y.toFixed(1);
        for (let i = 0; i < pts.length - 1; i++) {
          const p0 = pts[Math.max(0, i - 1)], p1 = pts[i], p2 = pts[i + 1], p3 = pts[Math.min(pts.length - 1, i + 2)];
          const c1y = clampY(p1.y + (p2.y - p0.y) / 6), c2y = clampY(p2.y - (p3.y - p1.y) / 6);
          d += ' C' + (p1.x + (p2.x - p0.x) / 6).toFixed(1) + ' ' + c1y.toFixed(1) + ' ' +
            (p2.x - (p3.x - p1.x) / 6).toFixed(1) + ' ' + c2y.toFixed(1) + ' ' +
            p2.x.toFixed(1) + ' ' + p2.y.toFixed(1);
        }
        return d;
      }

      let chartData = [];
      let chartGeo = null;

      function renderChart(a) {
        const m = currentMetric();
        styleTabs();

        const s = RW.series(a.code);
        let joinedIdx = 0;
        for (let i = 0; i < s.length; i++) { if (s[i].views > 0) { joinedIdx = i; break; } }
        const n = state.days === 0 ? s.length - joinedIdx : Math.min(state.days, s.length);
        chartData = s.slice(s.length - n);
        const vals = chartData.map((r) => m.get(r));

        const wrap = $('chart-wrap'), svg = $('chart');
        const W = Math.max(320, wrap.clientWidth), H = Math.max(230, wrap.clientHeight);
        svg.setAttribute('viewBox', '0 0 ' + W + ' ' + H);

        const padL = 52, padR = 14, padT = 16, padB = 30;
        const iw = W - padL - padR, ih = H - padT - padB;
        const max = niceCeil(Math.max.apply(null, vals.concat([1])) * 1.08);
        const x = (i) => padL + (chartData.length === 1 ? iw / 2 : (i / (chartData.length - 1)) * iw);
        const y = (v) => padT + ih - (v / max) * ih;
        const clampY = (v) => Math.max(padT, Math.min(padT + ih, v));
        chartGeo = { x, y, W, H };

        const pts = vals.map((v, i) => ({ x: x(i), y: y(v) }));
        const line = smoothPath(pts, clampY);
        const area = line + ' L' + x(chartData.length - 1).toFixed(1) + ' ' + (padT + ih) + ' L' + x(0).toFixed(1) + ' ' + (padT + ih) + ' Z';

        let grid = '';
        for (let g = 1; g <= 4; g++) {
          const gv = max * g / 4;
          const gy = y(gv).toFixed(1);
          grid += '<line x1="' + padL + '" y1="' + gy + '" x2="' + (W - padR) + '" y2="' + gy + '" stroke="rgba(255,255,255,0.05)"/>' +
            '<text x="' + (padL - 10) + '" y="' + (+gy + 3) + '" text-anchor="end" font-size="10" fill="rgba(235,235,235,0.32)" font-family="Hanken Grotesk,sans-serif">' + fmtTick(gv, m.money) + '</text>';
        }
        grid += '<line x1="' + padL + '" y1="' + (padT + ih) + '" x2="' + (W - padR) + '" y2="' + (padT + ih) + '" stroke="rgba(255,255,255,0.09)"/>';

        let ticks = '';
        const tickCount = Math.min(6, chartData.length);
        for (let k = 0; k < tickCount; k++) {
          const idx = Math.round(k * (chartData.length - 1) / Math.max(1, tickCount - 1));
          const lbl = chartData[idx].date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
          const anchor = k === 0 ? 'start' : k === tickCount - 1 ? 'end' : 'middle';
          ticks += '<text x="' + x(idx).toFixed(1) + '" y="' + (H - 9) + '" text-anchor="' + anchor + '" font-size="10" fill="rgba(235,235,235,0.32)" font-family="Hanken Grotesk,sans-serif">' + lbl + '</text>';
        }

        const total = vals.reduce((sum, v) => sum + v, 0);
        const avg = total / Math.max(1, vals.length);
        const avgY = y(avg).toFixed(1);
        const avgLine =
          '<line x1="' + padL + '" y1="' + avgY + '" x2="' + (W - padR) + '" y2="' + avgY + '" stroke="' + alphaColor(m.color, 0.35) + '" stroke-dasharray="2 5" stroke-width="1"/>' +
          '<text x="' + (W - padR) + '" y="' + (+avgY - 5) + '" text-anchor="end" font-size="9" letter-spacing="1" fill="' + alphaColor(m.color, 0.55) + '" font-family="Hanken Grotesk,sans-serif">AVG ' + fmtTick(avg, m.money) + '</text>';

        $('chart').innerHTML =
          '<defs><linearGradient id="fillg" x1="0" y1="0" x2="0" y2="1">' +
          '<stop offset="0%" stop-color="' + alphaColor(m.color, 0.30) + '"/>' +
          '<stop offset="72%" stop-color="' + alphaColor(m.color, 0.04) + '"/>' +
          '<stop offset="100%" stop-color="' + alphaColor(m.color, 0) + '"/></linearGradient></defs>' +
          grid + ticks +
          '<path d="' + area + '" fill="url(#fillg)"/>' +
          '<path d="' + line + '" fill="none" stroke="' + alphaColor(m.color, 0.16) + '" stroke-width="6" stroke-linejoin="round" stroke-linecap="round"/>' +
          '<path d="' + line + '" fill="none" stroke="' + m.color + '" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"/>' +
          avgLine +
          '<line id="guide" y1="' + padT + '" y2="' + (padT + ih) + '" stroke="' + alphaColor(m.color, 0.35) + '" stroke-dasharray="3 3" visibility="hidden"/>' +
          '<circle id="dot-halo" r="8" fill="' + alphaColor(m.color, 0.18) + '" visibility="hidden"/>' +
          '<circle id="dot" r="3.6" fill="' + m.color + '" stroke="#13223F" stroke-width="1.5" visibility="hidden"/>';

        $('chart-range-label').textContent = rangeLabel();

        const best = chartData.reduce((b, r) => (m.get(r) > m.get(b) ? r : b), chartData[0]);
        let deltaHtml = '<span class="v">-</span>';
        if (state.days) {
          const prevSlice = s.slice(Math.max(0, s.length - 2 * n), s.length - n);
          const prevTotal = prevSlice.reduce((sum, r) => sum + m.get(r), 0);
          if (prevTotal > 0) {
            const ch = (total - prevTotal) / prevTotal * 100;
            deltaHtml = '<span class="v ' + (ch >= 0 ? 'up' : 'down') + '">' + (ch >= 0 ? '▲ +' : '▼ ') + ch.toFixed(0) + '%</span>';
          }
        }
        $('chart-meta').innerHTML =
          '<div class="m"><span class="label">Total · ' + m.label + '</span><span class="v">' + fmtVal(total, m.money) + '</span></div>' +
          '<div class="m"><span class="label">Vs previous</span>' + deltaHtml + '</div>' +
          '<div class="m"><span class="label">Best day</span><span class="v">' + fmtVal(m.get(best), m.money) + '<small>' + best.date.toLocaleDateString('en-US', { month: 'short', day: 'numeric' }) + '</small></span></div>' +
          '<div class="m"><span class="label">Daily average</span><span class="v">' + fmtVal(avg, m.money) + '</span></div>';

        bindChartHover();
      }

      function bindChartHover() {
        const wrap = $('chart-wrap'), svg = $('chart'), tip = $('chart-tip');
        wrap.onmousemove = (e) => {
          if (!chartData.length || !chartGeo) return;
          const m = currentMetric();
          const rect = svg.getBoundingClientRect();
          const relX = e.clientX - rect.left;
          const first = chartGeo.x(0), last = chartGeo.x(chartData.length - 1);
          let i = Math.round((relX - first) / Math.max(1, last - first) * (chartData.length - 1));
          i = Math.max(0, Math.min(chartData.length - 1, i));
          const r = chartData[i];
          const cx = chartGeo.x(i), cy = chartGeo.y(m.get(r));
          svg.querySelector('#guide').setAttribute('x1', cx);
          svg.querySelector('#guide').setAttribute('x2', cx);
          svg.querySelector('#guide').setAttribute('visibility', 'visible');
          ['dot', 'dot-halo'].forEach((id) => {
            const el = svg.querySelector('#' + id);
            el.setAttribute('cx', cx); el.setAttribute('cy', cy); el.setAttribute('visibility', 'visible');
          });
          tip.style.opacity = '1';
          tip.style.left = cx + 'px';
          tip.style.top = cy + 'px';
          tip.innerHTML = r.date.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' }) +
            ' · <span style="color:' + m.color + ';font-weight:500">' + fmtVal(m.get(r), m.money) + ' ' + m.label.toLowerCase() + '</span>';
        };
        wrap.onmouseleave = () => {
          tip.style.opacity = '0';
          ['guide', 'dot', 'dot-halo'].forEach((id) => {
            const el = svg.querySelector('#' + id);
            if (el) el.setAttribute('visibility', 'hidden');
          });
        };
      }

      // redraw on card resize (chart fills the row height)
      let roTick = 0;
      new ResizeObserver(() => {
        cancelAnimationFrame(roTick);
        roTick = requestAnimationFrame(() => {
          if (state.aff && !$('main').hidden) renderChart(state.aff);
        });
      }).observe($('chart-wrap'));

      /* ---------- your page ---------- */
      function renderPage(a) {
        const display = 'rewiremission.com/affiliate?a=' + a.handle;
        const url = RW.localPageUrlFor(a);
        $('page-handle').textContent = '@' + a.handle;
        $('page-url-text').textContent = display;
        $('preview-addr').textContent = display;
        $('open-btn').href = url;
        const iframe = $('preview-iframe');
        if (iframe.dataset.src !== url) { iframe.src = url; iframe.dataset.src = url; }
        $('copy-btn').onclick = function () {
          const btn = this;
          navigator.clipboard.writeText('https://' + display).then(() => {
            btn.classList.add('copied');
            btn.lastChild.textContent = ' Copied';
            setTimeout(() => { btn.classList.remove('copied'); btn.lastChild.textContent = ' Copy'; }, 1600);
          });
        };
      }

      /* ---------- funnel + money ---------- */
      function renderFunnel(a, t) {
        const steps = [
          ['Link clicks', t.clicks, t.clicks, null],
          ['Installs', t.installs, t.clicks, 'of clicks'],
          ['Trial starts', t.trials, t.installs, 'of installs'],
          ['Paid members', t.paid, t.trials, 'of trials']
        ];
        $('funnel').innerHTML = steps.map((s) => {
          const w = t.clicks > 0 ? Math.max(2, s[1] / t.clicks * 100) : 0;
          const conv = s[3] ? RW.pct(s[1], s[2]) + ' ' + s[3] : rangeLabel();
          return '<div class="step"><div class="row1"><span class="n">' + s[0] + '</span><span class="v">' + RW.num(s[1]) + '</span></div>' +
            '<div class="bar"><i style="width:' + w + '%"></i></div>' +
            '<div class="conv">' + conv + '</div></div>';
        }).join('');
      }

      function renderMoney(a, t) {
        const youPct = Math.round(a.share * 100);
        const rwPct = 100 - youPct;
        const you = t.verifiedRevenue * a.share;
        const rewire = t.verifiedRevenue - you;
        $('money').innerHTML =
          '<div class="m-row"><span class="k">Est. revenue (incl. open trials)</span><span class="v">' + RW.money(t.estRevenue) + '</span></div>' +
          '<div class="m-row"><span class="k">Verified revenue</span><span class="v">' + RW.money(t.verifiedRevenue) + '</span></div>' +
          '<div class="share-block">' +
            '<div class="row1"><span class="label">Your assigned revenue share</span><span class="pct">' + youPct + '%</span></div>' +
            '<div class="share-bar"><i style="width:' + youPct + '%"></i></div>' +
            '<div class="share-legend">' +
              '<span><i class="sw you"></i>You · ' + youPct + '% · <b>' + RW.money(you) + '</b></span>' +
              '<span><i class="sw rw"></i>Rewire · ' + rwPct + '% · <b>' + RW.money(rewire) + '</b></span>' +
            '</div>' +
          '</div>' +
          '<div class="earn"><span class="label">Your earnings · ' + rangeLabel() + '</span><span class="big">' + RW.money(t.earnings) + '</span></div>' +
          '<p class="footnote">Estimated revenue projects trials still in progress. Verified revenue is confirmed after the refund window and is what your share is paid on.</p>';
      }

      /* ---------- payouts ---------- */
      function renderPayouts(a) {
        const p = RW.payoutSummary(a.code);
        const next = p.nextPayout.toLocaleDateString('en-US', { month: 'long', day: 'numeric' });
        $('payout-tiles').innerHTML =
          '<div class="p"><span class="label">Pending balance</span><span class="v accent">' + RW.money(p.pending) + '</span></div>' +
          '<div class="p"><span class="label">Paid to date</span><span class="v">' + RW.money(p.paidToDate) + '</span></div>' +
          '<div class="p"><span class="label">Next payout</span><span class="v">' + next + '</span></div>';

        const labels = { paid: 'Paid', due: 'Processing', accruing: 'Accruing' };
        $('payout-rows').innerHTML = p.months.slice().reverse().map((m) =>
          '<tr><td><span class="month">' + m.label + '</span></td>' +
          '<td class="num">' + RW.money(m.verifiedRevenue) + '</td>' +
          '<td class="num">' + Math.round(a.share * 100) + '%</td>' +
          '<td class="num">' + RW.money(m.earnings) + '</td>' +
          '<td style="text-align:right"><span class="pill ' + m.status + '">' + labels[m.status] + '</span></td></tr>'
        ).join('');
      }

      /* ---------- boot ---------- */
      const saved = RW.byCode(localStorage.getItem(LS_KEY));
      if (saved) enter(saved); else showGate();
    </script>
  </body>
</html>
